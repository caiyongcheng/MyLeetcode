<idea-plugin>
    <id>letcode.testutil.runner</id>
    <name>LeetCode TestUtil Runner</name>
    <version>1.1.0</version>
    <vendor email="noreply@example.com">Local</vendor>
    <idea-version since-build="233"/>
    <description><![CDATA[
        Run or debug current Java class through letcode.utils.TestUtilRunner.
        Fetch LeetCode daily/random questions and submit solutions.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="LeetCode"
                    factoryClass="letcode.plugin.LeetCodeToolWindowFactory"
                    anchor="right"
                    icon="/icons/leetcode_toolwindow.svg"
                    secondary="true"/>
    </extensions>

    <actions>
        <action id="letcode.testutil.runner.action"
                class="letcode.plugin.RunWithTestUtilAction"
                text="Run via TestUtilRunner"
                description="Run or debug current Java class with letcode.utils.TestUtilRunner">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>
        <action id="letcode.leetcode.daily.action"
                class="letcode.plugin.GenerateLeetCodeDailyQuestionAction"
                text="Generate LeetCode Daily Question"
                description="Fetch today's LeetCode daily challenge and generate Java solution stub">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="letcode.leetcode.submit.action"
                class="letcode.plugin.SubmitLeetCodeSolutionAction"
                text="Submit LeetCode Solution"
                description="Submit current Java solution to LeetCode and show judge result">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
